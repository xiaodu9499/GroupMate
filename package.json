{
  "name": "groupmate",
  "version": "0.1.0",
  "description": "Local-first channel agent runtime for enterprise chats.",
  "type": "module",
  "bin": {
    "groupmate": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "vitest run"
  },
  "keywords": [
    "agent",
    "chatops",
    "dingtalk",
    "feishu",
    "wecom",
    "codex",
    "claude-code",
    "cursor"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
